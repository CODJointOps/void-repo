# Template file for 'claude-desktop'
pkgname=claude-desktop
version=1.9255.2
revision=2
archs="x86_64"
depends="electron35 desktop-file-utils hicolor-icon-theme"
short_desc="Claude AI Desktop Application"
maintainer="rich@bandaholics.cash"
license="custom:Claude"
homepage="https://claude.ai"
changelog="https://github.com/patrickjaja/claude-desktop-bin/releases"
repository="nonfree"
restricted=yes
_tag=v1.9255.2-2
distfiles="https://github.com/patrickjaja/claude-desktop-bin/releases/download/${_tag}/claude-desktop-${version}-linux.tar.gz"
checksum=b6590bfe2ea6adb2d7a33a297994bd79301fa888c0c56f8b93e1f0e87ef79850

do_install() {
	vmkdir usr/lib/${pkgname}
	vcopy app/* usr/lib/${pkgname}

	vbin ${FILESDIR}/claude-desktop

	vinstall ${FILESDIR}/claude-desktop.desktop 0644 usr/share/applications

	if [ -f icons/claude-desktop.png ]; then
		vinstall icons/claude-desktop.png 0644 usr/share/icons/hicolor/256x256/apps
	fi
}
