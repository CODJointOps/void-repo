# Template file for 'zerotier-one'
pkgname=zerotier-one
version=1.16.1
revision=2
archs="x86_64 aarch64 x86_64-musl aarch64-musl"
build_style=gnu-makefile
make_build_args="ZT_SSO_SUPPORTED=0"
make_build_target="one"
short_desc="Smart programmable Ethernet switch for planet Earth"
maintainer="Wizzard <rich@bandaholics.cash>"
license="MPL-2.0"
