checksum=abbe8c84f27f8454f923148573f42c6a4d22d947f50359c6fe3c977a89fd0f63

do_install() {
	vbin zerotier-one
	ln -s zerotier-one "${DESTDIR}/usr/bin/zerotier-cli"
	ln -s zerotier-one "${DESTDIR}/usr/bin/zerotier-idtool"
	vman doc/zerotier-one.8
	vman doc/zerotier-cli.1
	vman doc/zerotier-idtool.1
	vmkdir var/lib/zerotier-one
}

post_install() {
	vlicense LICENSE.txt
	vsv zerotier-one
}
