# Template file for 'helium-browser'
pkgname=helium-browser
version=0.14.3.1
revision=1
archs="x86_64 aarch64"
hostmakedepends="curl"
depends="desktop-file-utils hicolor-icon-theme libnotify xdg-utils"
short_desc="Private, fast, and honest web browser"
maintainer="Wizzard"
license="GPL-3.0-only"
homepage="https://helium.computer"
changelog="https://github.com/imputnet/helium-linux/releases"

lib32disabled=yes
noshlibprovides=yes
noverifyrdeps=yes

case "${XBPS_TARGET_MACHINE}" in
x86_64*)
	_arch=x86_64
	checksum=98404a938f96f4c8b2bbb92bed0422fd60c7e1591ec6bd69c4dc5e8b67212793
	;;
aarch64*)
	_arch=arm64
	checksum=8fa248704be9ec4475a306ffed407ad777d600b24021c005f7dd9b2e707e3448
	;;
*)
	broken="No distfiles available for this target"
	;;
esac

distfiles="https://github.com/imputnet/helium-linux/releases/download/${version}/helium-${version}-${_arch}_linux.tar.xz"
wrksrc="helium-${version}-${_arch}_linux"

do_install() {
	install -dm755 "${DESTDIR}/opt/${pkgname}" \
		"${DESTDIR}/usr/bin" \
		"${DESTDIR}/usr/share/applications"

	vcopy "*" "opt/${pkgname}"

	ln -sf "/opt/${pkgname}/helium-wrapper" "${DESTDIR}/usr/bin/helium"

	vinstall "${FILESDIR}/helium.desktop" 0644 usr/share/applications/

	install -dm755 "${DESTDIR}/usr/share/icons/hicolor/256x256/apps"
	vinstall product_logo_256.png 0644 usr/share/icons/hicolor/256x256/apps helium.png
	vinstall product_logo_256.png 0644 usr/share/pixmaps helium.png

	ln -sf /usr/lib/libnssckbi.so "${DESTDIR}/opt/${pkgname}/libnssckbi.so"
}

post_install() {
	curl --fail -sOL https://raw.githubusercontent.com/imputnet/helium/refs/heads/main/LICENSE
	vlicense LICENSE
}
